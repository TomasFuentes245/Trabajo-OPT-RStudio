	doi = {10.33960/issn-e.1885-9119.DT34},
	abstract = {Este documento de trabajo analiza las dinámicas de la confianza institucional en América Latina. Empleando datos del Latinobarómetro, genera una foto analítica que refleja la situación en esta materia en relación con los tres poderes que forman la triada del principio de separación de poderes: el legislativo, el
ejecutivo, y el poder judicial. Adicionalmente, el trabajo compara estos datos con los del resto del mundo y
España. La conclusión es que estamos en presencia de una importante crisis en materia de confianza institucional en el mundo, que se agrava todavía más en América Latina. El documento de trabajo desarrolla
una hipótesis explicativa de esta situación, que de confirmarse en futuros trabajos sobre la materia, abriría
una nueva vía de análisis de los fenómenos de confianza institucional y su vinculación con la mayor o menor
extensión de las esferas públicas nacionales.},
	language = {es},
	urldate = {2026-05-12},
	journal = {Documentos de Trabajo},
	author = {Estella De Noriega, Antonio},
	month = may,
	year = {2020},
