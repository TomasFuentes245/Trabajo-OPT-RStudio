p10stgbs,
p13st_h,
p18st),
~ifelse(as.numeric(.) %in% c(-1, -2, 97),
NA,
as.numeric(.))))
proc_bdd <- na.omit(proc_bdd)
proc_bdd <- proc_bdd %>% rename("satisfaccion_democracia"= P11STGBS_A,
"apoyo_democracia"=p10stgbs,
"conf_institucion_electoral"=p13st_h,
"escala_izq_der"=p18st)
proc_bdd$satisfaccion_democracia <- (proc_bdd$satisfaccion_democracia+proc_bdd$apoyo_democracia+proc_bdd$conf_institucion_electoral+proc_data)
proc_bdd$satisfaccion_democracia <- (proc_bdd$satisfaccion_democracia+proc_bdd$apoyo_democracia+proc_bdd$conf_institucion_electoral+proc_bdd)
View(proc_bdd)
